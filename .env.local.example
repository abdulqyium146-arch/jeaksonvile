# ─── Analytics ────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID (G-XXXXXXXXXX)
# Get it from: https://analytics.google.com → Admin → Data Streams
NEXT_PUBLIC_GA_ID=

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Sign up at https://resend.com — free tier handles 3,000 emails/month
RESEND_API_KEY=

# Email address that receives contact form submissions
NOTIFY_EMAIL=info@jaxlockkey.com

# Sender address (must match a verified Resend domain)
FROM_EMAIL=noreply@jaxlockkey.com

# ─── Site ─────────────────────────────────────────────────────────────────────
# Override in production if deploying to a custom domain
# NEXT_PUBLIC_SITE_URL=https://www.jaxlockkey.com
